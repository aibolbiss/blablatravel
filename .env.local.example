NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Только для сервера, НЕ NEXT_PUBLIC_ — иначе ключ попадёт в клиентский бандл.
# Supabase → Settings → API → service_role key. Нужен только для удаления
# пользователей в админке (/admin) — обходит RLS, обращаться с ним как с паролем.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Mapbox → Account → Access tokens. Публичный токен (pk.*), безопасен для клиента.
NEXT_PUBLIC_MAPBOX_TOKEN=YOUR_MAPBOX_TOKEN
